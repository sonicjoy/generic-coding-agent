# API and durable state
GCA_API_TOKEN=replace-with-at-least-16-random-characters
GCA_DATA_DIR=/var/lib/gca
GCA_ALLOWED_REPOSITORY_HOSTS=github.com,gitlab.com
GCA_MODEL_CONFIG_PATHS=/etc/gca/models.yaml
# Optional JSON grants keyed by canonical host/project and tool name
GCA_TOOL_SECRET_GRANTS='{"github.com/owner/repository":{"query_metrics":["METRICS_TOKEN"]}}'

# Publication: auto (default) requires a matching SCM token at enqueue time.
# Set off for agent-only dry runs without opening a PR/MR.
# GCA_PUBLISH_MODE=auto

# Optional GitHub ingress/publication
GCA_GITHUB_WEBHOOK_SECRET=replace-with-at-least-16-random-characters
GCA_ALLOWED_GITHUB_PROJECTS=owner/repository
GCA_GITHUB_TOKEN=
GCA_GITHUB_HOST=github.com
GCA_GITHUB_TRIGGER_LABEL=gca-run

# Nested Docker hosts that reject --cpus/--memory (cgroupv2 threaded mode)
# can disable limits or rely on automatic retry without limits.
# GCA_DOCKER_DISABLE_RESOURCE_LIMITS=0

# Optional GitLab ingress/publication (legacy single-project mode)
GCA_GITLAB_WEBHOOK_SECRET=replace-with-at-least-16-random-characters
GCA_ALLOWED_GITLAB_PROJECTS=group/repository
GCA_GITLAB_TOKEN=
GCA_GITLAB_HOST=gitlab.com
GCA_GITLAB_TRIGGER_LABEL=gca-run
# Exact numeric bot user id used to ignore self-authored notes/MR events.
# GCA_GITLAB_BOT_USER_ID=

# Preferred multi-registration GitLab Issue Agent mode. Each registration binds
# one project webhook URL: POST /webhooks/gitlab/{registration_id}
# GCA_GITLAB_WEBHOOK_REGISTRATIONS='[{"id":"prod-main","gitlab_instance":"https://gitlab.example","project_id":42,"project_path":"group/repository","hook_uuid":"...","signing_secret":"at-least-16-chars","trigger_label":"gca-run","minimum_actor_access_level":30,"repository_url":"https://gitlab.example/group/repository.git"}]'

# Optional static membership map for actor authorization checks when the live
# GitLab membership API is unavailable: {"project_id:user_id": access_level}
# GCA_GITLAB_MEMBERSHIP_LEVELS={"42:7":40}

# Two-key auto-merge operator ceiling (also requires repo publication.auto_merge).
# Comma-separated numeric GitLab project IDs. Empty disables auto-merge everywhere.
# GCA_ALLOW_AUTO_MERGE_PROJECTS=

# Retention (seconds). Workspaces default 24h; structured events default 30d.
# GCA_WORKSPACE_RETENTION_SECONDS=86400
# GCA_LOG_RETENTION_SECONDS=2592000

# Worker behavior
GCA_LEASE_SECONDS=1800
GCA_POLL_SECONDS=2
# Optional default agent step budget for webhook and /runs submissions that
# omit max_steps (1..1000). When unset, the worker falls back to the target
# repository's .gca/config.yaml runtime.max_steps (default 25).
# GCA_DEFAULT_MAX_STEPS=100
